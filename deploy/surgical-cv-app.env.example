# surgical-cv FastAPI app environment
#
# Copy this file to .env in the project root, fill in values, chmod 600.
# Do NOT commit .env (it is gitignored).
#
# After editing .env, restart the unit:
#   sudo systemctl restart surgical-cv-app

# =============================================================================
# REQUIRED
# =============================================================================

# Session signing secret. Must be at least 32 bytes.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Enforced by F-009 in app/auth.py::_load_session_secret.
APP_SESSION_SECRET=

# DSM WebAPI URL for user authentication.
# Convention: use the 10GbE direct link (private subnet 10.10.0.0/24).
# Example: https://10.10.0.2:5001
NAS_DSM_URL=

# =============================================================================
# OPTIONAL — defaults shown commented
# =============================================================================

# DSM TLS verification.
# F-020: defaults to off (0) until DSM cert pinning is implemented.
# Security note: with verify=off, a MITM on the 10GbE link could intercept
# DSM auth requests. Acceptable given the private direct-attach subnet posture.
# Flip to 1 once cert pinning lands.
# DSM_TLS_VERIFY=0

# Pipeline NAS root mount path. Defaults to /mnt/nas.
# PIPELINE_NAS_ROOT=/mnt/nas

# App SQLite DB path. Defaults to <project>/app/db/app.db.
# APP_DB_PATH=

# Case manifest path. Defaults to a NAS-derived path.
# Useful for pointing at a test manifest during development.
# CASE_MANIFEST_PATH=

# =============================================================================
# DO NOT SET IN PRODUCTION
# =============================================================================
# MOCK_AUTH=1      # bypasses DSM auth; local development only
# APP_DEV_MODE=1   # enables dev mode features
